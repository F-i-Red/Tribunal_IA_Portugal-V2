# ============================================================
# TRIBUNAL IA PORTUGAL — CONFIGURAÇÃO
# ============================================================

# Chave API do OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-A TUA API CHAVE AQUI

# ============================================================
# MODELO — escolhe UM e comenta os outros
# ============================================================

# --- GRATUITOS (sem custo, qualidade limitada) ---
MODELO=openrouter/free
#MODELO=google/gemini-2.0-flash-exp:free
#MODELO=google/gemma-3-27b-it:free
#MODELO=meta-llama/llama-4-maverick:free
#MODELO=mistralai/mistral-small-3.1-24b-instruct:free
#MODELO=deepseek/deepseek-chat-v3-0324:free

# --- PAGOS BARATOS (~0.01-0.05€/caso — boa qualidade) ---
#MODELO=anthropic/claude-haiku-4-5
#MODELO=google/gemini-2.0-flash-001
#MODELO=google/gemma-3-27b-it
#MODELO=mistralai/mistral-small-24b

# --- PAGOS PREMIUM (~0.05-0.20€/caso — excelente qualidade) ---
#MODELO=anthropic/claude-sonnet-4.6
#MODELO=google/gemini-2.5-pro
#MODELO=openai/gpt-4.1-mini
#MODELO=deepseek/deepseek-chat-v3-0324

# MODELO ACTIVO (descomenta apenas UM):
MODELO=google/gemini-2.0-flash-exp:free

# ============================================================
# CONFIGURAÇÕES OPCIONAIS
# ============================================================
REQUEST_TIMEOUT=120
MAX_RETRIES=3
PASTA_ATAS=output_atas
LOG_LEVEL=INFO
GUARDAR_ATAS=true
WATERMARK_ATAS=true
DISCLAIMER_OBRIGATORIO=true
