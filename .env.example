# ============================================
# Tribunal IA Portugal — Configuração
# ============================================

# API Keys (obrigatório)
OPENROUTER_API_KEY=sk-or-v1- tua-chave-aqui

# Modelo Claude via OpenRouter
# Opções: claude-sonnet-4-6 (recomendado), claude-opus-4-6, claude-haiku-4-5-20251001
MODELO=claude-sonnet-4-6

# Configuração de Retry e Rate Limiting
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=2.0
REQUEST_TIMEOUT=60

# Dados
PASTA_LEIS=data/leis/
PASTA_PRECEDENTES=data/precedentes/

# Output
GUARDAR_ATAS=true
PASTA_ATAS=output_atas/

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Anonimização
ANONIMIZAR_ENTIDADES=true
TIPOS_ENTIDADES=PESSOA,LOCAL,ORGANIZACAO,DATA,CONTACTO,NIF

# Vector Store (Fase 2)
CHROMA_DB_PATH=data/chroma_db
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Segurança
WATERMARK_ATAS=true
DISCLAIMER_OBRIGATORIO=true
